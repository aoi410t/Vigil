# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# FFLogs OAuth client-credentials (PLAN §7). Create an API client at
# https://www.fflogs.com/api/clients/ and paste the values here.
FFLOGS_CLIENT_ID=
FFLOGS_CLIENT_SECRET=

# Postgres connection string used by SQLAlchemy + alembic (PLAN §6).
# Example: postgresql+psycopg://user:password@localhost:5432/fflogs_tracker
DATABASE_URL=

# FastAPI runtime
API_HOST=127.0.0.1
API_PORT=8000

# CORS origin for the React dev server
WEB_ORIGIN=http://localhost:5173
